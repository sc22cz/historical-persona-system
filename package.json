{
  "name": "historical-persona-system",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "concurrently -n backend,frontend -c blue,green \"npm run backend\" \"npm run frontend\"",
    "backend": "cd backend && ../venv/bin/uvicorn main:app --reload --port 8000",
    "frontend": "cd frontend && npm run dev"
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  }
}
